<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.EpsPublicSupervisorMapper">
    
    <resultMap type="EpsPublicSupervisor" id="EpsPublicSupervisorResult">
        <result property="supervisorId"    column="supervisor_id"    />
        <result property="userId"    column="user_id"    />
        <result property="realName"    column="real_name"    />
        <result property="phone"    column="phone"    />
        <result property="age"    column="age"    />
        <result property="gender"    column="gender"    />
        <result property="registerTime"    column="register_time"    />
    </resultMap>

    <sql id="selectEpsPublicSupervisorVo">
        select supervisor_id, user_id, real_name, phone, age, gender, register_time from eps_public_supervisor
    </sql>

    <select id="selectEpsPublicSupervisorList" parameterType="EpsPublicSupervisor" resultMap="EpsPublicSupervisorResult">
        <include refid="selectEpsPublicSupervisorVo"/>
        <where>  
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="realName != null  and realName != ''"> and real_name like concat('%', #{realName}, '%')</if>
            <if test="phone != null  and phone != ''"> and phone = #{phone}</if>
            <if test="age != null "> and age = #{age}</if>
            <if test="gender != null  and gender != ''"> and gender = #{gender}</if>
            <if test="registerTime != null "> and register_time = #{registerTime}</if>
        </where>
    </select>
    
    <select id="selectEpsPublicSupervisorBySupervisorId" parameterType="Long" resultMap="EpsPublicSupervisorResult">
        <include refid="selectEpsPublicSupervisorVo"/>
        where supervisor_id = #{supervisorId}
    </select>

    <insert id="insertEpsPublicSupervisor" parameterType="EpsPublicSupervisor" useGeneratedKeys="true" keyProperty="supervisorId">
        insert into eps_public_supervisor
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="realName != null">real_name,</if>
            <if test="phone != null and phone != ''">phone,</if>
            <if test="age != null">age,</if>
            <if test="gender != null">gender,</if>
            <if test="registerTime != null">register_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="realName != null">#{realName},</if>
            <if test="phone != null and phone != ''">#{phone},</if>
            <if test="age != null">#{age},</if>
            <if test="gender != null">#{gender},</if>
            <if test="registerTime != null">#{registerTime},</if>
         </trim>
    </insert>

    <update id="updateEpsPublicSupervisor" parameterType="EpsPublicSupervisor">
        update eps_public_supervisor
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="realName != null">real_name = #{realName},</if>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="age != null">age = #{age},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="registerTime != null">register_time = #{registerTime},</if>
        </trim>
        where supervisor_id = #{supervisorId}
    </update>

    <delete id="deleteEpsPublicSupervisorBySupervisorId" parameterType="Long">
        delete from eps_public_supervisor where supervisor_id = #{supervisorId}
    </delete>

    <delete id="deleteEpsPublicSupervisorBySupervisorIds" parameterType="String">
        delete from eps_public_supervisor where supervisor_id in 
        <foreach item="supervisorId" collection="array" open="(" separator="," close=")">
            #{supervisorId}
        </foreach>
    </delete>
</mapper>