<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.GridCityMapper">
    
    <resultMap type="GridCity" id="GridCityResult">
        <result property="cityId"    column="city_id"    />
        <result property="cityName"    column="city_name"    />
        <result property="provinceId"    column="province_id"    />
        <result property="remarks"    column="remarks"    />
    </resultMap>

    <sql id="selectGridCityVo">
        select city_id, city_name, province_id, remarks from grid_city
    </sql>

    <select id="selectGridCityList" parameterType="GridCity" resultMap="GridCityResult">
        <include refid="selectGridCityVo"/>
        <where>  
            <if test="cityName != null  and cityName != ''"> and city_name like concat('%', #{cityName}, '%')</if>
            <if test="provinceId != null "> and province_id = #{provinceId}</if>
            <if test="remarks != null  and remarks != ''"> and remarks = #{remarks}</if>
        </where>
    </select>
    
    <select id="selectGridCityByCityId" parameterType="Long" resultMap="GridCityResult">
        <include refid="selectGridCityVo"/>
        where city_id = #{cityId}
    </select>

    <insert id="insertGridCity" parameterType="GridCity" useGeneratedKeys="true" keyProperty="cityId">
        insert into grid_city
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="cityName != null and cityName != ''">city_name,</if>
            <if test="provinceId != null">province_id,</if>
            <if test="remarks != null">remarks,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="cityName != null and cityName != ''">#{cityName},</if>
            <if test="provinceId != null">#{provinceId},</if>
            <if test="remarks != null">#{remarks},</if>
         </trim>
    </insert>

    <update id="updateGridCity" parameterType="GridCity">
        update grid_city
        <trim prefix="SET" suffixOverrides=",">
            <if test="cityName != null and cityName != ''">city_name = #{cityName},</if>
            <if test="provinceId != null">province_id = #{provinceId},</if>
            <if test="remarks != null">remarks = #{remarks},</if>
        </trim>
        where city_id = #{cityId}
    </update>

    <delete id="deleteGridCityByCityId" parameterType="Long">
        delete from grid_city where city_id = #{cityId}
    </delete>

    <delete id="deleteGridCityByCityIds" parameterType="String">
        delete from grid_city where city_id in 
        <foreach item="cityId" collection="array" open="(" separator="," close=")">
            #{cityId}
        </foreach>
    </delete>
</mapper>